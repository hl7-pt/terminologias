         fhir:display [ fhir:v "Porção da mucosa do segmento do cólon vista, mas outras áreas do segmento do cólon não são bem vistas devido a coloração, fezes residuais ou líquido opaco, 1" ] ;
         fhir:designation ( [
           fhir:language [ fhir:v "en" ] ;
