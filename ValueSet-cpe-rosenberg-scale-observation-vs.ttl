         fhir:display [ fhir:v "Gostaria de ter mais respeito por mim mesmo/a" ] ;
         fhir:designation ( [
           fhir:language [ fhir:v "en" ] ;
           fhir:value [ fhir:v "I wish I could have more respect for myself." ]
