             fhir:code [ fhir:v "900000000000013009" ] ;
             fhir:display [ fhir:v "Synonym" ]
           ] ;
           fhir:value [ fhir:v "Sou capaz de fazer coisas tão bem como a maioria das outras pessoas" ]
